# Copie ce fichier en .env et remplis les valeurs
# Récupère ces infos dans Supabase Dashboard > Settings > API

SUPABASE_URL=https://ton-projet.supabase.co
SUPABASE_ANON_KEY=ton_anon_key
SUPABASE_SERVICE_ROLE_KEY=ta_service_role_key

# OBLIGATOIRE : clé secrète des sessions (min 16 caractères, génère une chaîne aléatoire)
SESSION_SECRET=ta-chaine-secrete-tres-longue-et-aleatoire

# ─── CATALOGUE AUTO ───
# SteamSpy (gratuit, sans clé) : ajoute automatiquement des milliers de jeux Steam au catalogue au démarrage
# RAWG (nécessite une clé) : 500k+ jeux multi-plateformes, 20k requêtes/mois gratuites
# Obtenir une clé RAWG : https://rawg.io/apidocs
RAWG_API_KEY=ta_cle_api_rawg
# IGDB / Twitch (gratuit) : jeux Xbox, PS, Nintendo
# 1. Compte Twitch → https://dev.twitch.tv/console/apps → Register Your Application
# 2. Copie Client ID et génère un Client Secret
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Steam API key (obtenir sur https://steamcommunity.com/dev/apikey)
# Utilisée pour importer les jeux Steam d'un utilisateur + enrichir les infos
STEAM_API_KEY=ta_cle_api_steam

# Xbox API key (gratuite sur https://xbl.io)
XBL_API_KEY=ta_cle_api_xbl

# URL publique de ton app (pour callbacks OAuth/OpenID)
PUBLIC_URL=https://ton-app.render.com

# Google OAuth (connexion via Google)
# 1. Va sur https://console.cloud.google.com/apis/credentials → Crée des identifiants OAuth 2.0
# 2. Ajoute l'URI de redirection : https://ton-app.render.com/api/auth/google/callback
# 3. Copie le Client ID et le Client Secret ci-dessous
GOOGLE_CLIENT_ID=ton_google_client_id
GOOGLE_CLIENT_SECRET=ton_google_client_secret

# IDs des admins séparés par des virgules (OBLIGATOIRE pour utiliser /api/admin/reset et /api/debug/env)
ADMIN_IDS=

# Playnite Bridge : clé API pour sécuriser l'accès local (min 8 caractères)
BRIDGE_API_KEY=ta-cle-api-bridge-tres-secrete

# Epic Games : pas de clé nécessaire — le nom d'utilisateur est sauvegardé
# (l'import des jeux Epic nécessitera une future intégration API)

# PandaScore (gratuit, 1000 req/h) : données e-sport structurées (matchs, équipes, tournois)
# Inscription : https://pandascore.co → generer une clé API
PANDASCORE_API_KEY=ta_cle_api_pandascore

# esport.is (gratuit, 100 req/h) : API e-sport alternative (matchs live/upcoming/results)
# Générer une clé gratuitement : https://esport.is/api-keys
ESPORT_IS_API_KEY=ta_cle_api_esport_is
